{
  "name": "mcp-mapmyindia",
  "version": "0.1.0",
  "description": "MCP server for MapMyIndia (Mappls) APIs — geocoding, routing, places, and more",
  "keywords": [
    "mcp",
    "mcp-server",
    "mapmyindia",
    "mappls",
    "maps",
    "india",
    "geocoding",
    "routing",
    "directions",
    "places",
    "nearby"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bhuvnsh/mcp-mapmyindia.git"
  },
  "homepage": "https://github.com/bhuvnsh/mcp-mapmyindia#readme",
  "type": "module",
  "bin": {
    "mcp-mapmyindia": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
